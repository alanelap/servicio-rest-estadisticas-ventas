# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments and local configuration
.venv/
venv/
env/
.env
.env.*
!.env.example

# Packaging artifacts
build/
dist/
*.egg-info/

# Coverage and test artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/

# Runtime output
*.log
*.lock
data/*
!data/.gitkeep
!data/processed/
data/processed/*
!data/processed/.gitkeep

# Editor and operating-system files
.DS_Store
.idea/
.vscode/
*.swp

