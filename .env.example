# Entorno de la aplicación
APP_ENV=development
FLASK_DEBUG=0
HOST=0.0.0.0
BIND_ADDRESS=127.0.0.1
PORT=8000
WORKERS=2
LOG_LEVEL=INFO

# Fuentes y artefactos de datos
DATASET_PATH=data/ventas.csv
PROCESSED_DATA_PATH=data/processed/ventas.parquet
SUMMARY_CACHE_PATH=data/processed/statistics.json
METADATA_PATH=data/processed/metadata.json
QUALITY_REPORT_PATH=data/processed/quality_report.json
INGEST_ALLOWED_ROOT=.
STAT_TARGET_COLUMN=MONTO APLICADO

# Ingesta y límites operacionales
AUTO_INGEST=true
MAX_REQUEST_BODY_BYTES=16384
POLARS_MAX_THREADS=4
